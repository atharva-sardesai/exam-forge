VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Only used by supabase/seed.js; never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional, used by npm run db:migrate. Get it from Supabase Project Settings > Database.
DATABASE_URL=postgresql://postgres.your-ref:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres
